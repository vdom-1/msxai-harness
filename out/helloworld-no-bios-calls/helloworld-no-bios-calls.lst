  57	4023					SETMODE0:
  58	4023					        ; The BIOS is likely in Screen 1 (Graphics mode) when it calls the cartridge.
  59	4023					        ; We must fully initialize the VDP for Screen 0 (Text mode).
  60	4023	F3				        di
  61	4024					        
  62	4024					        ; CRITICAL: Reset VDP address flip-flop!
  63	4024					        ; The BIOS might have been interrupted or left the flip-flop in an unknown state.
  64	4024	DB	99			        in      a, (099h)
  65	4026					
  66	4026					        ; CRITICAL FOR MSX2: Set Register 14 to 0.
  67	4026					        ; This ensures all our VRAM writes go to the first 16KB bank.
  68	4026					        ; On MSX1, this safely mirrors to Reg 6 (Sprite Generator) which is ignored in Screen 0.
  69	4026	3E	00			        ld      a, 0
  70	4028	D3	99			        out     (099h), a
  71	402A	3E	8E			        ld      a, 14 | 080h    ; 8Eh
