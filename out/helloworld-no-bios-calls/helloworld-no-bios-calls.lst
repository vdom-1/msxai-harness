 236	4149	D3	99			        out     (099h), a       ; VDP Register 1 (Command/Status)
 237	414B	7C				        ld      a, h
 238	414C	F6	40			        or      040h            ; Bit 6 = 1 for Write
 239	414E	D3	99			        out     (099h), a       ; VDP Register 1
 240	4150					
 241	4150					        ; Write character
 242	4150	79				        ld      a, c
 243	4151	D3	98			        out     (098h), a       ; VDP Register 0 (Data)
 244	4153	FB				        ei
 245	4154					
 246	4154					        ; Increment cursor
