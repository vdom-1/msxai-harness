 216	4137					; Custom CHPUT - Writes a character to VDP directly
 217	4137					;----------------------------------------------------------
 218	4137					CUSTOM_CHPUT:
 219	4137	F5				        push    af
 220	4138	C5				        push    bc
 221	4139	D5				        push    de
