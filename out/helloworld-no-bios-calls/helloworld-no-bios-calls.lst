 251	415A					.cr:
 252	415A					        ; Carriage Return: Move cursor to beginning of the line
 253	415A					        ; cursor = cursor - (cursor % 40)
 254	415A	2A	00	C0		        ld      hl, (CURSOR)
 255	415D	01	28	00		        ld      bc, 40
 256	4160					.cr_div:
 257	4160	B7				        or      a               ; clear carry
 258	4161	ED	42			        sbc     hl, bc          ; hl = hl - 40
 259	4163	30	FB			        jr      nc, .cr_div     ; loop if hl >= 0
 260	4165	09				        add     hl, bc          ; add back 40, hl = remainder (cursor % 40)
 261	4166					        
 262	4166	EB				        ex      de, hl          ; de = remainder
 263	4167	2A	00	C0		        ld      hl, (CURSOR)
 264	416A	B7				        or      a
 265	416B	ED	52			        sbc     hl, de          ; hl = cursor - remainder
 266	416D	22	00	C0		        ld      (CURSOR), hl
 267	4170	18	0A			        jr      .end
